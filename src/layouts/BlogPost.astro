---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ColorScript from "../components/ColorScript.astro";
import Tags from "../components/Tags.astro";
import getTags from "../scripts/getTags";
import {
  AUTHOR_IMAGE,
  AUTHOR_NAME,
  DEFAULT_OG_IMAGE,
  PERSON_ID,
  SOCIAL_LINKS,
} from "../config";
import {
  DEFAULT_LOCALE,
  getLocaleCopy,
  getLocaleInfo,
  getLocalizedPosts,
  localizedPath,
} from "../lib/i18n";

let {
  content: {
    title,
    description,
    added,
    updated,
    tags,
    heroImage,
    slug,
    locale,
  },
} = Astro.props;

locale = locale ?? Astro.props.locale ?? DEFAULT_LOCALE;
const localeInfo = getLocaleInfo(locale);
const copy = getLocaleCopy(locale);
const posts = getLocalizedPosts(await getCollection("posts"), locale);
const allTags = getTags(posts);

const rawAdded = added;
const rawUpdated = updated ?? added;
const canonicalPath = localizedPath(locale, `/post/${slug}/`);
const image = heroImage ?? DEFAULT_OG_IMAGE;
const site = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(canonicalPath, site);
const imageURL = new URL(image, site);
const authorURL = new URL(localizedPath(locale, "/about/"), site);
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: new Date(rawAdded).toISOString(),
  dateModified: new Date(rawUpdated).toISOString(),
  mainEntityOfPage: canonicalURL.toString(),
  url: canonicalURL.toString(),
  image: [imageURL.toString()],
  inLanguage: locale,
  author: {
    "@type": "Person",
    "@id": PERSON_ID,
    name: AUTHOR_NAME,
    url: authorURL.toString(),
    image: new URL(AUTHOR_IMAGE, site).toString(),
    sameAs: SOCIAL_LINKS,
  },
  publisher: {
    "@type": "Person",
    "@id": PERSON_ID,
    name: AUTHOR_NAME,
    url: authorURL.toString(),
    image: new URL(AUTHOR_IMAGE, site).toString(),
  },
  keywords: tags,
};

added = new Date(added).toLocaleDateString(copy.post.dateLocale, {
  year: "numeric",
  month: "short",
  day: "numeric",
});

if (updated) {
  updated = new Date(updated).toLocaleDateString(copy.post.dateLocale, {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<html lang={localeInfo.lang}>
  <BaseHead
    title={`${title} | ${copy.siteTitle}`}
    description={description}
    image={image}
    imageAlt={copy.post.imageAlt(title)}
    type="article"
    canonical={canonicalPath}
    locale={locale}
    structuredData={blogPostingSchema}
  />

  <body>
    <Header locale={locale} />
    <main>
      <article>
        {
          heroImage && (
            <img
              width={720}
              height={360}
              src={heroImage}
              alt={copy.post.heroAlt(title)}
            />
          )
        }
        <h1 class="article-title">{title}</h1>
        {
          updated ? (
            <span>
              <time>{added}</time>, {copy.post.lastUpdated}{" "}
              <time>{updated}</time>
            </span>
          ) : (
            <span>{added && <time>{added}</time>}</span>
          )
        }
        <Tags tags={tags} locale={locale} />
        <hr />
        <div class="blog-post">
          <slot />
        </div>
      </article>
    </main>
    <Tags tags={allTags} all locale={locale} />
    <Footer locale={locale} />
    <ColorScript />
  </body>
</html>
