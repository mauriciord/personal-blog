---
import "../style/fonts.css";
import "../style/global.css";

import { AUTHOR_HANDLE, DEFAULT_OG_IMAGE } from "../config";
import {
  DEFAULT_LOCALE,
  getLocaleAlternates,
  getLocaleCopy,
  getLocaleInfo,
} from "../lib/i18n";

const {
  title,
  description,
  image = DEFAULT_OG_IMAGE,
  imageAlt = title,
  type = "website",
  canonical,
  robots = "index, follow",
  structuredData,
  locale = DEFAULT_LOCALE,
  alternatePath,
} = Astro.props;

const site = Astro.site ?? Astro.url.origin;
const canonicalURL = canonical
  ? new URL(canonical, site)
  : new URL(Astro.url.pathname, site);
const imageURL = new URL(image, site);
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const localeInfo = getLocaleInfo(locale);
const copy = getLocaleCopy(locale);
const alternateLinks = alternatePath ? getLocaleAlternates(alternatePath) : [];
---

<head>
  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonicalURL} />
  {
    alternateLinks.map(({ locale, path }) => (
      <link rel="alternate" hreflang={locale} href={new URL(path, site)} />
    ))
  }
  {
    alternatePath && (
      <link
        rel="alternate"
        hreflang="x-default"
        href={new URL(alternatePath, site)}
      />
    )
  }

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={imageURL} />
  <meta property="og:image:alt" content={imageAlt} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:creator" content={AUTHOR_HANDLE} />
  <meta name="twitter:image" content={imageURL} />
  <meta name="twitter:image:alt" content={imageAlt} />

  <!-- RSS Link -->
  <link
    rel="alternate"
    href={new URL(localeInfo.rss, site)}
    type="application/rss+xml"
    title={copy.siteTitle}
  />
  <link
    rel="alternate"
    href={new URL(localeInfo.llms, site)}
    type="text/plain"
    title="LLMs.txt"
  />

  <!-- Sitemap -->
  <link rel="sitemap" href={new URL("/sitemap-index.xml", site)} />

  {
    structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))
  }
</head>
