---
import HeaderLink from "./HeaderLink.astro";
import { DEFAULT_LOCALE, getLocaleCopy, getLocaleInfo } from "../lib/i18n";

const { locale = DEFAULT_LOCALE, title, description } = Astro.props;
const copy = getLocaleCopy(locale);
const info = getLocaleInfo(locale);
const englishInfo = getLocaleInfo(DEFAULT_LOCALE);
const portugueseInfo = getLocaleInfo("pt-BR");
---

<header>
  <div class="header-section">
    <div class="header-frame">
      <h1>{title ?? copy.siteTitle}</h1>
      <h2>{description ?? copy.siteDescription}</h2>
    </div>
    <div class="header-aside">
      <div class="language-toggle" role="group" aria-label="UI language">
        <a
          class:list={[
            "language-option",
            { active: locale === DEFAULT_LOCALE },
          ]}
          href={englishInfo.home}
          lang={englishInfo.lang}
          hreflang={englishInfo.lang}
          aria-current={locale === DEFAULT_LOCALE ? "true" : undefined}
        >
          EN
        </a>
        <span class="language-divider" aria-hidden="true">|</span>
        <a
          class:list={["language-option", { active: locale === "pt-BR" }]}
          href={portugueseInfo.home}
          lang={portugueseInfo.lang}
          hreflang={portugueseInfo.lang}
          aria-current={locale === "pt-BR" ? "true" : undefined}
        >
          PT-BR
        </a>
      </div>

      <div class="header-photo">
        <img
          src="/assets/SQUARE-profile_mustache_front.jpg"
          alt={copy.header.profileImageAlt}
          class="profile-img"
        />
      </div>
    </div>
  </div>
</header>
<nav>
  <HeaderLink href={info.home}>{copy.nav.home}</HeaderLink>
  <HeaderLink href={info.posts}>{copy.nav.posts}</HeaderLink>
  <HeaderLink href={info.about}>{copy.nav.about}</HeaderLink>
  <HeaderLink href={info.newsletter}>{copy.nav.newsletter}</HeaderLink>
  <HeaderLink
    href="https://linkedin.com/in/mauriciord"
    target="_blank"
    rel="noopener noreferrer">linkedin</HeaderLink
  >
  <HeaderLink
    href="https://github.com/mauriciord"
    target="_blank"
    rel="noopener noreferrer">github</HeaderLink
  >
</nav>
<style>
  .header-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .header-frame {
    flex: 1;
    min-width: 200px;
  }

  .header-aside {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .language-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    border: 1px solid var(--gray);
    border-radius: 999px;
    padding: 0.2rem;
    font-size: 0.85rem;
  }

  .language-option {
    border-radius: 999px;
    padding: 0.25rem 0.5rem;
    line-height: 1;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .language-option.active {
    background: var(--green);
    color: var(--black);
    font-weight: 700;
  }

  .language-option:not(.active):hover,
  .language-option:not(.active):focus-visible {
    color: var(--green);
  }

  .language-divider {
    color: var(--gray);
    line-height: 1;
  }

  .header-photo {
    flex-shrink: 0;
  }

  .profile-img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--gray);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .profile-img:hover {
    transform: scale(1.05);
    border-color: var(--green);
  }

  h2 {
    margin: 0.5em 0;
  }

  @media (max-width: 500px) {
    .header-section {
      flex-direction: column-reverse;
      text-align: center;
    }

    .header-frame {
      min-width: unset;
    }

    .header-aside {
      align-items: center;
    }

    .profile-img {
      width: 120px;
      height: 120px;
    }
  }
</style>
