---
import { DEFAULT_LOCALE, getLocaleCopy } from "../lib/i18n";

const { locale = DEFAULT_LOCALE } = Astro.props;
const copy = getLocaleCopy(locale);
const today = new Date();
---

<footer>
  &copy; {today.getFullYear()}. <a
    href="https://github.com/mauriciord/personal-blog"
    >{copy.footer.openSource}</a
  >! &lt;3
</footer>
<style>
  footer {
    padding: 25px;
    text-align: center;
    font-size: 0.8rem;
  }
</style>
