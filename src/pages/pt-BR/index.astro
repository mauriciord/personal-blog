---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HomePosts from "../../components/HomePosts.astro";
import ColorScript from "../../components/ColorScript.astro";
import Tags from "../../components/Tags.astro";
import AboutContent from "../../components/AboutContent.astro";
import {
  AUTHOR_IMAGE,
  AUTHOR_NAME,
  PERSON_ID,
  SITE_URL,
  SOCIAL_LINKS,
} from "../../config";
import {
  getLocaleCopy,
  getLocaleInfo,
  getLocalizedPosts,
  sortPosts,
} from "../../lib/i18n";
import getTags from "../../scripts/getTags";

const locale = "pt-BR";
const allPosts = await getCollection("posts");
const posts = sortPosts(getLocalizedPosts(allPosts, locale));
const tags = getTags(posts);
const site = Astro.site ?? SITE_URL;
const localeInfo = getLocaleInfo(locale);
const copy = getLocaleCopy(locale);
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: copy.siteTitle,
  description: copy.siteDescription,
  url: new URL(localeInfo.home, site).toString(),
  inLanguage: locale,
  author: { "@id": PERSON_ID },
};
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": PERSON_ID,
  name: AUTHOR_NAME,
  description: copy.authorDescription,
  url: new URL(localeInfo.about, site).toString(),
  image: new URL(AUTHOR_IMAGE, site).toString(),
  sameAs: SOCIAL_LINKS,
};
---

<!doctype html>
<html lang={localeInfo.lang}>
  <BaseHead
    title={copy.siteTitle}
    description={copy.siteDescription}
    canonical={localeInfo.home}
    locale={locale}
    alternatePath="/"
    structuredData={[websiteSchema, personSchema]}
  />
  <body>
    <Header locale={locale} />
    <main>
      <AboutContent locale={locale} />

      <br />

      <h3>{copy.home.recentPosts}</h3>

      <HomePosts allPosts={posts} locale={locale} />

      <p class="center">
        {copy.home.rssPrefix}
        <a href={localeInfo.rss}>{copy.home.rssLink}</a>
      </p>
      <br />

      <Tags tags={tags} all locale={locale} />
    </main>
    <Footer locale={locale} />
    <ColorScript />
  </body>
</html>
