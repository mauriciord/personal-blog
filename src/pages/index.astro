---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HomePosts from "../components/HomePosts.astro";
import ColorScript from "../components/ColorScript.astro";
import Tags from "../components/Tags.astro";
import AboutContent from "../components/AboutContent.astro";
import {
  AUTHOR_DESCRIPTION,
  AUTHOR_IMAGE,
  AUTHOR_NAME,
  PERSON_ID,
  SITE_DESCRIPTION,
  SITE_TITLE,
  SITE_URL,
  SOCIAL_LINKS,
} from "../config";
import getTags from "../scripts/getTags";

const posts = await getCollection("posts");
const tags = getTags(posts);
const site = Astro.site ?? SITE_URL;
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: new URL("/", site).toString(),
  inLanguage: "en-US",
  author: { "@id": PERSON_ID },
};
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": PERSON_ID,
  name: AUTHOR_NAME,
  description: AUTHOR_DESCRIPTION,
  url: new URL("/about", site).toString(),
  image: new URL(AUTHOR_IMAGE, site).toString(),
  sameAs: SOCIAL_LINKS,
};
---

<!doctype html>
<html lang="en-us">
  <BaseHead
    title={SITE_TITLE}
    description={SITE_DESCRIPTION}
    canonical="/"
    structuredData={[websiteSchema, personSchema]}
  />
  <body>
    <Header title={SITE_TITLE} />
    <main>
      <AboutContent />

      <br />

      <h3>Here's my most recent posts</h3>

      <HomePosts allPosts={posts} />

      <p class="center">
        You can also <a href="/rss.xml"> subscribe with RSS! </a>
      </p>
      <br />

      <Tags tags={tags} all />
    </main>
    <Footer />
    <ColorScript />
  </body>
</html>
